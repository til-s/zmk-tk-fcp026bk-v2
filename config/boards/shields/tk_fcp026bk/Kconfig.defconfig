if SHIELD_TK_FCP026BK

config ZMK_KEYBOARD_NAME
    default "TK-FCP026BK"

config ZMK_USB
    default y

config ZMK_BLE
    default y

config I2C
    default y

config GPIO_MCP230XX
    default y

# デバウンス: ポーリング周期(50ms)より大きく設定することで
# I2Cの一時的な誤読み取りをキー入力として登録しない
config ZMK_KSCAN_DEBOUNCE_PRESS_MS
    default 80

config ZMK_KSCAN_DEBOUNCE_RELEASE_MS
    default 80

endif
