if SHIELD_TK_FCP026BK

config ZMK_KEYBOARD_NAME
    default "TK-FCP026BK"

config ZMK_USB
    default y

config ZMK_BLE
    default y

# I2C（MCP23017接続用）
config I2C
    default y

# GPIO expander（MCP23017）
config GPIO_MCP230XX
    default y

# MCP23017の割り込みサポートを無効化
# （ZMKポーリングモードでGPINTENが有効になりINTCAPラッチが起きる問題を回避）
config GPIO_MCP230XX_INTERRUPT
    default n

# デバウンス: ポーリング周期(50ms)より大きく設定することで
# I2Cの一時的な誤読み取りをキー入力として登録しない

endif
