/*
 * TK-FCP026BK Keymap v11
 * 86キー 日本語配列
 * 配線: Row=MCP23017(GPA0-7)、Col=XIAO Plus(D0-D3,D6-D14,D17-D19)
 *
 * bindingsの並び順: Row行優先 8行×16列=128エントリ
 *
 * レイヤー構成:
 *   Layer 0: default_layer  … 通常入力
 *   Layer 1: fn_layer       … FNキー押しっぱなし中
 *   Layer 2: numlock_layer  … NumLockキーでトグル（テンキー的数字入力）
 *
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    macros {
        numlock_toggle: numlock_toggle {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp KP_NUM>, <&tog 2>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
/* Col:          D0                D1                D2                D3                D6                D7                D8                D9                D10               D11               D12               D13               D14               D17               D18               D19           */
/* Row0 GPA0 */ &kp Q             &kp W             &kp E             &kp R             &kp U             &kp I             &kp O             &trans            &trans            &trans            &trans            &kp INT_YEN       &kp P             &numlock_toggle   &kp PAUSE_BREAK   &trans
/* Row1 GPA1 */ &kp TAB           &kp CAPS          &kp F3            &kp T             &kp Y             &kp RBKT          &kp F7            &trans            &trans            &trans            &kp LSHFT         &kp BSPC          &kp LBKT          &trans            &trans            &kp LGUI
/* Row2 GPA2 */ &kp A             &kp S             &kp D             &kp F             &kp J             &kp K             &kp L             &trans            &trans            &trans            &kp RSHFT         &trans            &kp SEMI          &trans            &trans            &trans
/* Row3 GPA3 */ &kp ESC           &trans            &kp F4            &kp G             &kp H             &kp F6            &mo 1             &kp UP            &trans            &kp SPACE         &trans            &kp F11           &kp QUOT          &kp LALT          &trans            &trans
/* Row4 GPA4 */ &kp Z             &kp X             &kp C             &kp V             &kp M             &kp COMMA         &kp DOT           &trans            &trans            &trans            &trans            &kp RET           &kp NUHS          &trans            &trans            &trans
/* Row5 GPA5 */ &kp INT5          &kp INT4          &kp INT2          &kp B             &kp N             &kp INT1          &kp K_APP         &kp LEFT          &kp RIGHT         &kp DOWN          &trans            &kp F12           &kp FSLH          &kp RALT          &trans            &trans
/* Row6 GPA6 */ &kp GRAVE         &kp F1            &kp F2            &kp N5            &kp N6            &kp EQUAL         &kp F8            &trans            &trans            &kp DEL           &trans            &kp F9            &kp MINUS         &trans            &kp LCTRL         &trans
/* Row7 GPA7 */ &kp N1            &kp N2            &kp N3            &kp N4            &kp N7            &kp N8            &kp N9            &trans            &trans            &trans            &trans            &kp F10           &kp N0            &kp PSCRN         &kp F5            &trans
            >;
        };

        fn_layer {
            bindings = <
/* Col:          D0                D1                D2                D3                D6                D7                D8                D9                D10               D11               D12               D13               D14               D17               D18               D19           */
/* Row0 GPA0 */ &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row1 GPA1 */ &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row2 GPA2 */ &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row3 GPA3 */ &trans            &trans            &trans            &trans            &trans            &trans            &trans            &kp PG_UP         &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row4 GPA4 */ &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row5 GPA5 */ &trans            &trans            &trans            &trans            &trans            &trans            &trans            &kp HOME          &kp END           &kp PG_DN         &trans            &trans            &trans            &trans            &trans            &trans
/* Row6 GPA6 */ &trans            &trans            &trans            &bt BT_CLR        &trans            &trans            &trans            &trans            &trans            &kp INS           &trans            &trans            &trans            &trans            &trans            &trans
/* Row7 GPA7 */ &bt BT_SEL 0      &bt BT_SEL 1      &bt BT_SEL 2      &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
            >;
        };

        numlock_layer {
            bindings = <
/* Col:          D0                D1                D2                D3                D6                D7                D8                D9                D10               D11               D12               D13               D14               D17               D18               D19           */
/* Row0 GPA0 */ &trans            &trans            &trans            &trans            &kp N4            &kp N5            &kp N6            &trans            &trans            &trans            &trans            &trans            &kp KP_MINUS      &numlock_toggle   &trans            &trans
/* Row1 GPA1 */ &trans            &trans            &trans            &trans            &kp N7            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row2 GPA2 */ &trans            &trans            &trans            &trans            &kp N1            &kp N2            &kp N3            &trans            &trans            &trans            &trans            &trans            &kp KP_PLUS       &trans            &trans            &trans
/* Row3 GPA3 */ &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row4 GPA4 */ &trans            &trans            &trans            &trans            &kp N0            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row5 GPA5 */ &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &kp KP_SLASH      &trans            &trans            &trans
/* Row6 GPA6 */ &trans            &trans            &trans            &trans            &kp N6            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans            &trans
/* Row7 GPA7 */ &trans            &trans            &trans            &trans            &kp N7            &kp N8            &kp N9            &trans            &trans            &trans            &trans            &trans            &kp KP_MULTIPLY   &trans            &trans            &trans
            >;
        };
    };
}; 
